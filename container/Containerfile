# Base image is `Manjaro Linux`

# ---------------------------------------------------------------------------
# Layer 1: Base image, minimum installation only for chezmoi apply
#          And install that must be used in our environment.
# ---------------------------------------------------------------------------
FROM docker.io/manjarolinux/base:latest AS base

LABEL org.opencontainers.image.title="dotfiles-manjaro"
LABEL org.opencontainers.image.description="Manjaro base image for testing dotfiles"

# Layer 1-1: Get arguments from Outer ENV values
ARG HOST_UID # GIVEN BY `Makefile` as a default
ARG HOST_GID # GIVEN BY `Makefile` as a default
ARG USERNAME # GIVEN BY `.env` (required; build fails if not set)

# Layer 1-2: seed a Japan-optimized pacman mirrorlist, then install the
# Layer 1 pacman package set from dependencies/layer_1/pacman.txt (the
# single source of truth per spec 20 I5/I8; generated by `make gen-deps`).

# Mirrorlist: copy the curated Japan mirrorlist from the build context as
# /etc/pacman.d/mirrorlist so every subsequent `pacman -Sy` uses fast local
# mirrors. This is a pacman-mirrors "custom mirrorlist"; reset with
# `pacman-mirrors -c all` / `-id`.
# Package list: `dependencies/` is outside the container/ build context, so
# it is exposed via a named BuildKit context (`--build-context deps=...` in
# the Makefile) and read with `COPY --from=deps`. Comments and blank lines
# are stripped before `pacman -S`.
# Package cache: a BuildKit cache mount (`--mount=type=cache`) keeps
# pacman's downloaded tarballs in /var/cache/pacman/pkg across builds, so a
# cache-miss rebuild reuses them instead of re-downloading. The mount is NOT
# written to the image layer, so it adds no bloat; the previous `rm -rf` is
# dropped. (Clear the cache with `podman build` cache pruning.)
# Runs as root (the default until USER ${USERNAME} below).
COPY bind/layer_1_files/pacman_mirrorlist /etc/pacman.d/mirrorlist
COPY --from=deps layer_1/pacman.txt /tmp/pacman_deps.txt
RUN --mount=type=cache,target=/var/cache/pacman/pkg \
    pacman -Sy --noconfirm --needed $(sed 's/#.*//' /tmp/pacman_deps.txt | xargs)

# Layer 1-3: create the user and set up ownership.

# Remap the existing `builder` user/group to the host uid/gid (and rename it
# to $USERNAME when set) so bind-mounted files keep correct ownership.
# manjarolinux/base ships `builder` at 1000:1000, so uid/gid only change when
# they differ from the host. Also set the login shell to zsh.

RUN if [ "$(id -g builder)" != "${HOST_GID}" ]; then \
        groupmod -g ${HOST_GID} builder; \
    fi \
 && if [ "$(id -u builder)" != "${HOST_UID}" ] || [ "$(id -g builder)" != "${HOST_GID}" ]; then \
        usermod -u ${HOST_UID} -g ${HOST_GID} builder; \
    fi \
 && if [ -n "${USERNAME}" ] && [ "${USERNAME}" != "builder" ]; then \
        usermod -l ${USERNAME} -d /home/${USERNAME} -m builder \
     && groupmod -n ${USERNAME} builder; \
    fi \
 && usermod -s /usr/bin/zsh ${USERNAME}

# Layer 1-4: create the user and use it as `paru` user

# paru + makepkg refuse to run as root. install-paru itself bootstraps paru from the AUR PKGBUILD if the
# binary is missing, then installs everything from paru/packages.txt.

RUN set -e; \
    if id -u "${HOST_UID}" >/dev/null 2>&1; then \
        ACTUAL_USER=$(getent passwd "${HOST_UID}" | cut -d: -f1); \
        usermod -s /usr/bin/zsh "${ACTUAL_USER}" || true; \
        usermod -d "/home/${USERNAME}" "${ACTUAL_USER}"; \
    else \
        if ! getent group "${HOST_GID}" >/dev/null; then \
            groupadd -g "${HOST_GID}" "${USERNAME}"; \
        fi; \
        useradd -m -u "${HOST_UID}" -g "${HOST_GID}" -s /usr/bin/zsh "${USERNAME}"; \
        ACTUAL_USER="${USERNAME}"; \
    fi; \
    install -d -o "${HOST_UID}" -g "${HOST_GID}" -m 0755 "/home/${USERNAME}"; \
    echo "${ACTUAL_USER} ALL=(ALL) NOPASSWD: ALL" > /etc/sudoers.d/dotfiles; \
    chmod 0440 /etc/sudoers.d/dotfiles

# Switch to the non-root ${USERNAME} for all subsequent steps (Layer 2
# `chezmoi apply` and the future `paru`/`makepkg` builds, which refuse to
# run as root). The sudoers provisioning above MUST run as root, so USER
# is set only after it.
USER ${USERNAME}

# ---------------------------------------------------------------------------
# Layer 2: chezmoi apply our dotfiles
# ---------------------------------------------------------------------------
# TODO: Run `pacman config` and install some required packages (like `base-devel`)
#          (Only for first time. and then it's cached.
#           it is used for installation of packages that requires some ENV value
#           it should be overridden when `chezmoi apply` is run again
#           in the container.)

FROM base AS no-config-base
