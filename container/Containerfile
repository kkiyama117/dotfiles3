# Base image is `Manjaro Linux`
# Read `docs/specifications/20-container-rules.md` for whole rules of the container build.
# Read `docs/specifications/21-container-build-flow.md` for layer ordering and package selection.

# ---------------------------------------------------------------------------
# Layer 0: Base image
# ---------------------------------------------------------------------------
FROM docker.io/manjarolinux/base:latest AS base

# ---------------------------------------------------------------------------
# Layer 1: Minimum installation only for chezmoi apply
#          And install that must be used in our environment.
# ---------------------------------------------------------------------------

LABEL org.opencontainers.image.title="dotfiles-manjaro"
LABEL org.opencontainers.image.description="Manjaro base image for testing dotfiles"

# Layer 1-1: Get arguments from Outer ENV values
ARG HOST_UID # GIVEN BY `Makefile` as a default
ARG HOST_GID # GIVEN BY `Makefile` as a default
ARG USERNAME # GIVEN BY `.env` (required; build fails if not set)

# Layer 1-2: seed a Japan-optimized pacman mirrorlist, then install the
# Layer 1 pacman package set from dependencies/layer_1/pacman.txt (the
# single source of truth per spec 20 I5/I8; generated by `make gen-deps`).

# Mirrorlist: copy the curated Japan mirrorlist from the build context as
# /etc/pacman.d/mirrorlist so every subsequent `pacman -Sy` uses fast local
# mirrors. This is a pacman-mirrors "custom mirrorlist"; reset with
# `pacman-mirrors -c all` / `-id`.
# Package list: `dependencies/` is outside the container/ build context, so
# it is exposed via a named BuildKit context (`--build-context deps=...` in
# the Makefile) and read with `COPY --from=deps`. Comments and blank lines
# are stripped before `pacman -S`.
# Package cache: a BuildKit cache mount (`--mount=type=cache`) keeps
# pacman's downloaded tarballs in /var/cache/pacman/pkg across builds, so a
# cache-miss rebuild reuses them instead of re-downloading. The mount is NOT
# written to the image layer, so it adds no bloat; the previous `rm -rf` is
# dropped. (Clear the cache with `podman build` cache pruning.)
# Runs as root (the default until USER ${USERNAME} below).
COPY bind/layer_1_files/pacman_mirrorlist /etc/pacman.d/mirrorlist
COPY --from=deps layer_1/pacman.txt /tmp/pacman_deps.txt
RUN --mount=type=cache,target=/var/cache/pacman/pkg \
    pacman -Syu --noconfirm --needed $(sed 's/#.*//' /tmp/pacman_deps.txt | xargs)

# Layer 1-3: create the user and set up ownership.

# Remap the existing `builder` user/group to the host uid/gid (and rename it
# to $USERNAME when set) so bind-mounted files keep correct ownership.
# manjarolinux/base ships `builder` at 1000:1000, so uid/gid only change when
# they differ from the host. Also set the login shell to zsh.

RUN if [ "$(id -g builder)" != "${HOST_GID}" ]; then \
        groupmod -g ${HOST_GID} builder; \
    fi \
 && if [ "$(id -u builder)" != "${HOST_UID}" ] || [ "$(id -g builder)" != "${HOST_GID}" ]; then \
        usermod -u ${HOST_UID} -g ${HOST_GID} builder; \
    fi \
 && if [ -n "${USERNAME}" ] && [ "${USERNAME}" != "builder" ]; then \
        usermod -l ${USERNAME} -d /home/${USERNAME} -m builder \
     && groupmod -n ${USERNAME} builder; \
    fi \
 && usermod -s /usr/bin/zsh ${USERNAME}

# Layer 1-4: create the non-root user and use it as `paru` user

# paru + makepkg refuse to run as root. install-paru itself bootstraps paru from the AUR PKGBUILD if the
# binary is missing, then installs everything from paru/packages.txt.

RUN set -e; \
    if id -u "${HOST_UID}" >/dev/null 2>&1; then \
        ACTUAL_USER=$(getent passwd "${HOST_UID}" | cut -d: -f1); \
        usermod -s /usr/bin/zsh "${ACTUAL_USER}" || true; \
        usermod -d "/home/${USERNAME}" "${ACTUAL_USER}"; \
    else \
        if ! getent group "${HOST_GID}" >/dev/null; then \
            groupadd -g "${HOST_GID}" "${USERNAME}"; \
        fi; \
        useradd -m -u "${HOST_UID}" -g "${HOST_GID}" -s /usr/bin/zsh "${USERNAME}"; \
        ACTUAL_USER="${USERNAME}"; \
    fi; \
    install -d -o "${HOST_UID}" -g "${HOST_GID}" -m 0755 "/home/${USERNAME}"; \
    echo "${ACTUAL_USER} ALL=(ALL) NOPASSWD: ALL" > /etc/sudoers.d/dotfiles; \
    chmod 0440 /etc/sudoers.d/dotfiles

# Switch to the non-root ${USERNAME} for all subsequent steps (Layer 2
# `chezmoi apply` and the future `paru`/`makepkg` builds, which refuse to
# run as root). The sudoers provisioning above MUST run as root, so USER
# is set only after it.
USER ${USERNAME}

# Layer 1-5: XDG-compliant home subdirectories
#
# Owner-correct directories must exist so the four runtime mounts (one bind
# for chezmoi source, three named volumes for cargo/rustup/mise) attach to
# a properly-owned ~/.local/share/ parent. install -d as root, then return
# to ${USERNAME} so subsequent stages stay non-root.
USER root
RUN install -d -o ${HOST_UID} -g ${HOST_GID} -m 0755 \
    /home/${USERNAME}/.local \
    /home/${USERNAME}/.local/share \
    /home/${USERNAME}/.local/share/cargo \
    /home/${USERNAME}/.local/share/rustup \
    /home/${USERNAME}/.local/share/mise \
    /home/${USERNAME}/.local/share/chezmoi
USER ${USERNAME}

# ---------------------------------------------------------------------------
# Stage 2: build-prepass
#
# Run `chezmoi apply` with `build_mode = true` against a scratch destination
# so the resolved environment (CARGO_HOME, RUSTUP_HOME, MISE_DATA_DIR, PATH)
# becomes sourceable in Stage 3 without leaking secrets. The scratch
# destination is removed in Stage 4 before the final image layer.
# ---------------------------------------------------------------------------
FROM base AS build-prepass

COPY --from=srcroot --chown=${HOST_UID}:${HOST_GID} . /tmp/chezmoi-src

RUN mkdir -p /home/${USERNAME}/.config/chezmoi \
 && cat > /home/${USERNAME}/.config/chezmoi/chezmoi.toml <<'TOML'
[data]
build_mode = true
TOML

RUN mkdir -p /tmp/build-home \
 && chezmoi apply \
      --source /tmp/chezmoi-src \
      --destination /tmp/build-home \
      --no-tty \
      --force

# ---------------------------------------------------------------------------
# Stage 3: toolchain
#
# Install rustup, mise, and cargo binaries with ENV inherited from the
# build-prepass scratch render. Each RUN is a fresh shell, so each must
# `source /tmp/build-home/.zshenv` to materialize CARGO_HOME / RUSTUP_HOME /
# MISE_DATA_DIR. BuildKit cache mounts (uid/gid require Podman >= 4.0) keep
# the cargo registry index / git checkouts across rebuilds without bloating
# image layers.
# ---------------------------------------------------------------------------
FROM build-prepass AS toolchain

RUN --mount=type=cache,target=/home/${USERNAME}/.cache/cargo-install,uid=${HOST_UID},gid=${HOST_GID} \
    zsh -c 'set -eo pipefail; \
      source /tmp/build-home/.zshenv; \
      curl --proto "=https" --tlsv1.2 -sSf https://sh.rustup.rs \
        | sh -s -- -y --no-modify-path --default-toolchain stable --profile minimal; \
    '

RUN zsh -c 'set -eo pipefail; \
      source /tmp/build-home/.zshenv; \
      curl https://mise.run | sh; \
    '

COPY --from=deps layer_3/cargo.txt /tmp/cargo_tools.txt

RUN --mount=type=cache,target=/home/${USERNAME}/.local/share/cargo/registry,uid=${HOST_UID},gid=${HOST_GID} \
    --mount=type=cache,target=/home/${USERNAME}/.local/share/cargo/git,uid=${HOST_UID},gid=${HOST_GID} \
    zsh -c 'set -eo pipefail; \
      source /tmp/build-home/.zshenv; \
      pkgs=$(sed "s/#.*//" /tmp/cargo_tools.txt | xargs); \
      if [ -n "$pkgs" ]; then \
        cargo install --locked $pkgs; \
      else \
        echo "toolchain: cargo install list is empty -- skipping"; \
      fi; \
    '

# ---------------------------------------------------------------------------
# Stage 4: runtime (final)
#
# Strip Stage 2/3 scratch artifacts (so they cannot ride in the final layer),
# install the entrypoint that re-runs chezmoi apply at container start with
# build_mode = false, and set USER/WORKDIR/ENTRYPOINT/CMD.
# ---------------------------------------------------------------------------
FROM toolchain AS runtime

USER root
RUN rm -rf /tmp/chezmoi-src /tmp/build-home /home/${USERNAME}/.config/chezmoi
COPY --chown=root:root bind/layer_4_files/entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod 0755 /usr/local/bin/entrypoint.sh

USER ${USERNAME}
WORKDIR /home/${USERNAME}
ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
CMD ["zsh"]
