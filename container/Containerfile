# Base image is `Manjaro Linux`
# Read `docs/specifications/20-container-rules.md` for whole rules of the container build.
# Read `docs/specifications/21-container-build-flow.md` for layer ordering and package selection.

# ---------------------------------------------------------------------------
# Layer 0: Base image
# ---------------------------------------------------------------------------
FROM docker.io/manjarolinux/base:latest AS base

# ---------------------------------------------------------------------------
# Layer 1: Minimum installation only for chezmoi apply
#          And install that must be used in our environment.
# ---------------------------------------------------------------------------

LABEL org.opencontainers.image.title="dotfiles-manjaro"
LABEL org.opencontainers.image.description="Manjaro base image for testing dotfiles"

# Layer 1-1: Get arguments from Outer ENV values
ARG HOST_UID # GIVEN BY `Makefile` as a default
ARG HOST_GID # GIVEN BY `Makefile` as a default
ARG USERNAME # GIVEN BY `.env` (required; build fails if not set)

# Layer 1-2: seed a Japan-optimized pacman mirrorlist, then install the
# Layer 1 pacman package set from dependencies/layer_1/pacman.txt (the
# single source of truth per spec 20 I5/I8; generated by `make gen-deps`).

# Mirrorlist: copy the curated Japan mirrorlist from the build context as
# /etc/pacman.d/mirrorlist so every subsequent `pacman -Sy` uses fast local
# mirrors. This is a pacman-mirrors "custom mirrorlist"; reset with
# `pacman-mirrors -c all` / `-id`.
# Package list: `dependencies/` is outside the container/ build context, so
# it is exposed via a named BuildKit context (`--build-context deps=...` in
# the Makefile) and read with `COPY --from=deps`. Comments and blank lines
# are stripped before `pacman -S`.
# Package cache: a BuildKit cache mount (`--mount=type=cache`) keeps
# pacman's downloaded tarballs in /var/cache/pacman/pkg across builds, so a
# cache-miss rebuild reuses them instead of re-downloading. The mount is NOT
# written to the image layer, so it adds no bloat; the previous `rm -rf` is
# dropped. (Clear the cache with `podman build` cache pruning.)
# Runs as root (the default until USER ${USERNAME} below).
COPY bind/layer_1_files/pacman_mirrorlist /etc/pacman.d/mirrorlist
COPY --from=deps layer_1/pacman.txt /tmp/pacman_deps.txt
RUN --mount=type=cache,target=/var/cache/pacman/pkg \
    pacman -Syu --noconfirm --needed $(sed 's/#.*//' /tmp/pacman_deps.txt | xargs)

# Layer 1-3: create the user and set up ownership.

# Remap the existing `builder` user/group to the host uid/gid (and rename it
# to $USERNAME when set) so bind-mounted files keep correct ownership.
# manjarolinux/base ships `builder` at 1000:1000, so uid/gid only change when
# they differ from the host. Also set the login shell to zsh.

RUN if [ "$(id -g builder)" != "${HOST_GID}" ]; then \
        groupmod -g ${HOST_GID} builder; \
    fi \
 && if [ "$(id -u builder)" != "${HOST_UID}" ] || [ "$(id -g builder)" != "${HOST_GID}" ]; then \
        usermod -u ${HOST_UID} -g ${HOST_GID} builder; \
    fi \
 && if [ -n "${USERNAME}" ] && [ "${USERNAME}" != "builder" ]; then \
        usermod -l ${USERNAME} -d /home/${USERNAME} -m builder \
     && groupmod -n ${USERNAME} builder; \
    fi \
 && usermod -s /usr/bin/zsh ${USERNAME}

# Layer 1-4: create the non-root user and use it as `paru` user

# paru + makepkg refuse to run as root. install-paru itself bootstraps paru from the AUR PKGBUILD if the
# binary is missing, then installs everything from paru/packages.txt.

RUN set -e; \
    if id -u "${HOST_UID}" >/dev/null 2>&1; then \
        ACTUAL_USER=$(getent passwd "${HOST_UID}" | cut -d: -f1); \
        usermod -s /usr/bin/zsh "${ACTUAL_USER}" || true; \
        usermod -d "/home/${USERNAME}" "${ACTUAL_USER}"; \
    else \
        if ! getent group "${HOST_GID}" >/dev/null; then \
            groupadd -g "${HOST_GID}" "${USERNAME}"; \
        fi; \
        useradd -m -u "${HOST_UID}" -g "${HOST_GID}" -s /usr/bin/zsh "${USERNAME}"; \
        ACTUAL_USER="${USERNAME}"; \
    fi; \
    install -d -m 0755 "/home/${USERNAME}" \
 && chown "${HOST_UID}:${HOST_GID}" "/home/${USERNAME}"; \
    echo "${ACTUAL_USER} ALL=(ALL) NOPASSWD: ALL" > /etc/sudoers.d/dotfiles; \
    chmod 0440 /etc/sudoers.d/dotfiles

# Switch to the non-root ${USERNAME} for all subsequent steps (Layer 2
# `chezmoi apply` and the future `paru`/`makepkg` builds, which refuse to
# run as root). The sudoers provisioning above MUST run as root, so USER
# is set only after it.
USER ${USERNAME}

# Layer 1-5: XDG-compliant home subdirectories
#
# Owner-correct directories must exist so the five runtime mounts (one bind
# for chezmoi source, four named volumes for cargo/rustup/mise/gnupg)
# attach to a properly-owned ~/.local/share/ parent. install -d as root,
# then return to ${USERNAME} so subsequent stages stay non-root.
USER root
RUN install -d -o ${HOST_UID} -g ${HOST_GID} -m 0755 \
    /home/${USERNAME}/.local \
    /home/${USERNAME}/.local/share \
    /home/${USERNAME}/.local/share/cargo \
    /home/${USERNAME}/.local/share/rustup \
    /home/${USERNAME}/.local/share/mise \
    /home/${USERNAME}/.local/share/chezmoi

# Layer 1-6: GNUPGHOME mountpoint (named volume dotfiles_gnupg).
#
# 0700 is mandatory for GNUPGHOME (gpg enforces strict permissions on its
# home and refuses otherwise). Kept as a separate RUN from the 0755
# toolchain dirs above so the mode is distinct and the intent is obvious.
# Owner-correct so Podman does not root-create an absent mountpoint at
# `make up` (the /home re-own failure mode, see Layer 5-2). The directory
# is empty at build time; no key material is baked into the image
# (spec 20 I4 / spec 13 I-S4 — the keyring lives only in the runtime
# named volume).
RUN install -d -o ${HOST_UID} -g ${HOST_GID} -m 0700 \
    /home/${USERNAME}/.local/share/gnupg
USER ${USERNAME}

# ---------------------------------------------------------------------------
# Stage 2: build-prepass
#
# Run `chezmoi apply` with `build_mode = true` against a scratch destination
# so the resolved environment (CARGO_HOME, RUSTUP_HOME, MISE_DATA_DIR, PATH)
# becomes sourceable in Stage 3 without leaking secrets. The scratch
# destination is removed in Stage 4 before the final image layer.
# ---------------------------------------------------------------------------
# Layer 2-1: use Container imange of Layer 1
FROM base AS build-prepass

# Layer 2-2: Apply minimum dotfiles with chezmoi:
COPY --from=srcroot --chown=${HOST_UID}:${HOST_GID} . /tmp/chezmoi-src

# generate temporary chezmoi config from the source-root template
RUN mkdir -p /home/${USERNAME}/.config/chezmoi
# Render the chezmoi config from .chezmoi.toml.tmpl with build_mode=true.
# BUILD_MODE is inline (not ENV) so it never reaches image Env / podman
# inspect. Runs as USER ${USERNAME} -> USERNAME-owned (the runtime
# entrypoint can overwrite it, and Layer 5-3 strips it regardless).
RUN BUILD_MODE=true chezmoi execute-template --init \
      < /tmp/chezmoi-src/.chezmoi.toml.tmpl \
      > /home/${USERNAME}/.config/chezmoi/chezmoi.toml

RUN mkdir -p /tmp/build-home \
 && chezmoi apply \
      --source /tmp/chezmoi-src \
      --destination /tmp/build-home \
      --no-tty \
      --force

# ---------------------------------------------------------------------------
# Stage 3: toolchain
#
# Install rustup, mise, and cargo binaries with ENV inherited from the
# build-prepass scratch render. Each RUN is a fresh shell, so each must
# `source /tmp/build-home/.zshenv` to materialize CARGO_HOME / RUSTUP_HOME /
# MISE_DATA_DIR. BuildKit cache mounts (uid/gid require Podman >= 4.0) keep
# the cargo registry index / git checkouts across rebuilds without bloating
# image layers.
# ---------------------------------------------------------------------------
# Layer 3-1: use Container imange of Layer 2
FROM build-prepass AS toolchain

# Layer 3-2: Install rustup with minimum zshenv
RUN --mount=type=cache,target=/home/${USERNAME}/.cache/cargo-install,uid=${HOST_UID},gid=${HOST_GID} \
    zsh -c 'set -eo pipefail; \
      source /tmp/build-home/.zshenv; \
      curl --proto "=https" --tlsv1.2 -sSf https://sh.rustup.rs \
        | sh -s -- -y --no-modify-path --default-toolchain stable --profile minimal; \
    '

# Layer 3-3: Install mise with minimum zshenv
RUN zsh -c 'set -eo pipefail; \
      source /tmp/build-home/.zshenv; \
      curl https://mise.run | sh; \
    '

# Layer 3-4: Install Rust-depend-programs with minimum zshenv
# copy cargo tools list from `deps` folder.
COPY --from=deps layer_3/cargo.txt /tmp/cargo_tools.txt

# install Rust programs with zshenv and config of container cache
RUN --mount=type=cache,target=/home/${USERNAME}/.local/share/cargo/registry,uid=${HOST_UID},gid=${HOST_GID} \
    --mount=type=cache,target=/home/${USERNAME}/.local/share/cargo/git,uid=${HOST_UID},gid=${HOST_GID} \
    zsh -c 'set -eo pipefail; \
      source /tmp/build-home/.zshenv; \
      pkgs=$(sed "s/#.*//" /tmp/cargo_tools.txt | xargs); \
      if [ -n "$pkgs" ]; then \
        cargo install --locked ${=pkgs}; \
      else \
        echo "toolchain: cargo install list is empty -- skipping"; \
      fi; \
    '

# ---------------------------------------------------------------------------
# Stage 4: aur
#
# Bootstrap paru from the AUR (paru is itself an AUR package and cannot
# be installed via pacman), then install the Layer 4 AUR package set from
# dependencies/layer_4/paru.txt (the single source of truth per spec 20
# I5/I8; generated by `make gen-deps`). Runs as non-root ${USERNAME};
# root escalation for pacman happens only via the Layer 1-4 NOPASSWD
# sudoers (spec 20 I7). BuildKit cache mounts keep the AUR clone/build
# cache and the pacman package cache across rebuilds without bloating
# image layers (resolves spec 21 Q1 / spec 20 Q2).
# ---------------------------------------------------------------------------
# Layer 4-0: use Container image of Layer 3 (toolchain)
FROM toolchain AS aur

# Layer 4-1: bootstrap paru via makepkg (non-root).
#
# paru is an AUR package, so install it the AUR way: clone the PKGBUILD,
# run makepkg -si (which installs paru + its repo deps via sudo pacman).
# `sudo pacman -Sy` refreshes the sync DB so makepkg's dependency
# resolution succeeds (no `-u`: Layer 1-2 already ran `pacman -Syu`).
# /tmp/paru-build is removed at the end so the clone never enters the
# image layer (I-AUR4).
RUN --mount=type=cache,target=/var/cache/pacman/pkg \
    --mount=type=cache,target=/home/${USERNAME}/.cache/paru,uid=${HOST_UID},gid=${HOST_GID} \
    --mount=type=cache,target=/home/${USERNAME}/.local/share/cargo/registry,uid=${HOST_UID},gid=${HOST_GID} \
    --mount=type=cache,target=/home/${USERNAME}/.local/share/cargo/git,uid=${HOST_UID},gid=${HOST_GID} \
    zsh -c 'set -eo pipefail; \
      source /tmp/build-home/.zshenv; \
      sudo pacman -Sy --noconfirm; \
      git clone https://aur.archlinux.org/paru.git /tmp/paru-build; \
      cd /tmp/paru-build && makepkg -si --noconfirm --needed; \
      rm -rf /tmp/paru-build; \
    '

# Layer 4-2: install the AUR package set from the generated list.
#
# `dependencies/` is outside the container/ build context, so it is
# exposed via the named BuildKit context `deps` (see Makefile) and read
# with `COPY --from=deps`. Comments and blank lines are stripped before
# `paru -S`. The list contains only `manager = "paru"` entries; `paru`
# itself is `manager = "custom"` (doc-only) and is NOT in this list, so
# the bootstrap step above is the sole install path for `paru` and the
# bulk call never re-submits it as a `paru -S` target. `--needed` makes
# the remaining installs idempotent.
#
# `${=pkgs}` (not `$pkgs`): unlike sh/bash, zsh does not word-split a bare
# unquoted parameter by default, so `paru -S --noconfirm --needed $pkgs`
# passed the whole space-joined string ("neovim-git starship tmux") as one
# malformed target instead of three, which paru reported as "could not
# find all required packages" for all of them. `${=pkgs}` is zsh's
# explicit split operator and restores the intended per-package args.
COPY --from=deps layer_4/paru.txt /tmp/paru_deps.txt
RUN --mount=type=cache,target=/var/cache/pacman/pkg \
    --mount=type=cache,target=/home/${USERNAME}/.cache/paru,uid=${HOST_UID},gid=${HOST_GID} \
    --mount=type=cache,target=/home/${USERNAME}/.local/share/cargo/registry,uid=${HOST_UID},gid=${HOST_GID} \
    --mount=type=cache,target=/home/${USERNAME}/.local/share/cargo/git,uid=${HOST_UID},gid=${HOST_GID} \
    zsh -c 'set -eo pipefail; \
      source /tmp/build-home/.zshenv; \
      pkgs=$(sed "s/#.*//" /tmp/paru_deps.txt | xargs); \
      if [ -n "$pkgs" ]; then \
        paru -S --noconfirm --needed ${=pkgs}; \
      else \
        echo "aur: paru install list is empty -- skipping"; \
      fi; \
    '

# ---------------------------------------------------------------------------
# Stage 5: runtime (final)
#
# Strip Stage 2/3/4 scratch artifacts (so they cannot ride in the final
# layer), install the entrypoint that re-runs chezmoi apply at container
# start with build_mode = false, and set USER/WORKDIR/ENTRYPOINT/CMD.
# ---------------------------------------------------------------------------
# Layer 5-1: use Container image of Layer 4 (aur)
FROM aur AS runtime

# Layer 5-2: Bake minimum home (.zshenv) + fix /home ownership
#
# Two things happen here, all as root:
#
# -  Bake a MINIMUM HOME so the image boots into a wizard-free,
#    PATH/env-equipped, chezmoi-apply-ready shell INDEPENDENT of the
#    runtime entrypoint (which re-runs `chezmoi apply` against the
#    host bind). This covers two real failure modes:
#      a) `make exec` racing the entrypoint's `chezmoi apply` (the
#         exec'd zsh would otherwise see a `$HOME` with NO zsh startup
#         files -> `zsh/newuser` module sources `/usr/share/zsh/scripts/
#         newuser` and the first-run wizard prompts). With `~/.zshenv`
#         baked, the module's "none of .zshenv/.zprofile/.zshrc/.zlogin
#         exist" condition is never met, so the wizard never fires.
#      b) The container being exec'd with the entrypoint bypassed (e.g.
#         `podman run --entrypoint ...`). `~/.zshenv` makes the shell
#         usable; `chezmoi apply` then needs the entrypoint (or a
#         manually-created config) — the baked home no longer ships a
#         `chezmoi.toml` (see Layer 5-3).
#    `dot_zshenv.tmpl` has NO chezmoi template directives and NO
#    `build_mode` branch, so the build-prepass render is byte-identical to
#    what the runtime `chezmoi apply --force` produces; the runtime apply
#    just overwrites it with the same content (idempotent). Only
#    `~/.zshenv` is baked here — `~/.config/chezmoi/chezmoi.toml` is NOT
#    baked: the build-prepass toml (`build_mode = true`, rendered from
#    `.chezmoi.toml.tmpl` by `chezmoi execute-template --init` with
#    `BUILD_MODE=true`, USERNAME-owned) is stripped in Layer 5-3, and the
#    runtime entrypoint re-renders it from the same `.chezmoi.toml.tmpl`
#    (`BUILD_MODE` unset -> `false`) as ${USERNAME} before `chezmoi apply`.
# -  Restore /home/${USERNAME} ownership: Stage 3 cache mounts (e.g. the
#    --mount=type=cache under /home/${USERNAME}/.cache) cause Podman to
#    create a missing parent as root, which re-roots /home/${USERNAME}
#    itself. The toolchain subdirs (.local/share/{cargo,rustup,mise}) keep
#    their 1000:1000 owner, but the home dir must be re-chowned here so the
#    runtime entrypoint (running as ${USERNAME}) can write into ~.
#
# `/tmp/build-home` (the rest of the build-prepass render) is dropped after
# the minimum `.zshenv` is copied out, and `/tmp/chezmoi-src` is dropped too,
# so neither scratch tree rides in the final layer (spec 21 acceptance #5).
# `/run/user/${HOST_UID}` is baked here so the shared .zshenv line
# `export XDG_RUNTIME_DIR=/run/user/$UID` works identically on host
# (pam_systemd creates it) and container (no pam_systemd; /run is rootfs,
# not tmpfs, so the build-time dir persists at runtime). Tools that
# MkdirAll($XDG_RUNTIME_DIR) (e.g. `chezmoi cd`) then find it present.
USER root
RUN set -eux; \
    install -d -o ${HOST_UID} -g ${HOST_GID} -m 0755 /home/${USERNAME}/.config/chezmoi; \
    cp /tmp/build-home/.zshenv /home/${USERNAME}/.zshenv; \
    chown ${HOST_UID}:${HOST_GID} /home/${USERNAME}/.zshenv; \
    chown ${HOST_UID}:${HOST_GID} /home/${USERNAME}; \
    install -d -o ${HOST_UID} -g ${HOST_GID} -m 0700 /run/user/${HOST_UID}

# Layer 5-3: remove duplicated files and strip build artifacts
# Remove `/etc/skel` bash remnants (`.bashrc`, `.bash_profile`,
# `.bash_logout`, `.profile`) that Layer 1-3's `usermod -l ... -d
# /home/${USERNAME} -m builder` moved out of the base image's `builder`
# home. They are not chezmoi-managed, so `chezmoi apply` never removes
# them; they would otherwise linger in `$HOME` forever.
# Also strip the build-prepass `chezmoi.toml` (`build_mode = true`,
# rendered from `.chezmoi.toml.tmpl` by `chezmoi execute-template --init`
# with `BUILD_MODE=true`, USERNAME-owned) that rides the Stage chain into
# the runtime image: the runtime entrypoint re-renders this file from the
# same template (`BUILD_MODE` unset -> `false`) as ${USERNAME}, so the
# baked copy is removed as a clean-slate invariant (it would be safe to
# overwrite now that it is USERNAME-owned, but stripping guarantees no
# stale carry-forward).
RUN set -eux; \
    rm -rf /tmp/build-home; \
    rm -rf /tmp/chezmoi-src; \
    rm -f /home/${USERNAME}/.config/chezmoi/chezmoi.toml; \
    rm -f /home/${USERNAME}/.bashrc \
          /home/${USERNAME}/.bash_profile \
          /home/${USERNAME}/.bash_logout \
          /home/${USERNAME}/.profile;

# Layer 5-4: Run the entrypoint of the container with some ENVs
COPY --chown=root:root bind/layer_5_files/entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod 0755 /usr/local/bin/entrypoint.sh
USER ${USERNAME}
WORKDIR /home/${USERNAME}
ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
CMD ["zsh"]
