# Managed by chezmoi. Sourced by all zsh invocations (including non-interactive
# subshells), so this is the right place for environment defaults that should
# be visible to every process started from a zsh in the container.
# And it should contain only the environment variables that are
# common to all zsh invocations. If we can use it in other zsh config files,
# (especially managed by `sheldon`), we should.

# Secrets MUST NOT live here — chezmoi bakes this file into the image-bound
# source tree at /var/lib/chezmoi-source. Use Podman secrets for credentials.

# And almost all config of zsh are managed by [`sheldon`]
# (https://github.com/rossmacarthur/sheldon).
# This file is for common PATH or config to programs that are called by login
# shell or before loading `sheldon`.

################################################################################
# PATH config(general)
################################################################################
: "PATH config" && {
  ## Avoid duplicates
  typeset -U path PATH manpath sudo_path

  ## "SUDO" path config
  ## references:
  ## - https://github.com/clear-code/zsh.d/blob/master/zshenv

  typeset -xT SUDO_PATH sudo_path

  ## (N-/): 存在しないディレクトリは登録しない
  ##    パス(...): ...という条件にマッチするパスのみ残す
  ##            N: NULL_GLOBオプションを設定
  ##               globがマッチしなかったり存在しないパスを無視する
  ##            -: シンボリックリンク先のパスを評価
  ##            /: ディレクトリのみ残す
  sudo_path=({,/usr/pkg,/usr/local,/usr}/sbin(N-/))
  if [[ ( -a /sbin/id) && ( $(/sbin/id -u) -eq 0 )]]; then
      # rootの場合はsudo用のパスもPATHに加える。
      path=($sudo_path $path)
  else
      # 一般ユーザーの場合はsudo時にsudo用のパスをPATHに加える。
      alias sudo="sudo env PATH=\"$SUDO_PATH:$PATH\""
      :
  fi

  ## Add ".local/bin" to path
  path=($HOME/.local/bin(N-/) $path)
}

################################################################################
# Basic Env values config
################################################################################
: "Env config" && {
  : "SHELL (ZSH)" && {
    #export SHELL="${SHELL:-$(which zsh)}"
    if SHELL=$(builtin command -v zsh); then
      export SHELL
    else
      unset SHELL
    fi
  }
  : "TERM" && {
    ## TERM config
    export TERM="${TERM:-xterm-256color}"
  }
  : "LANG, TZ" && {
    export LANG="${LANG:-ja_JP.UTF-8}"
    export LC_CTYPE=en_US.UTF-8
    export LANGUAGE=ja_JP.UTF-8:en_US.UTF-8:C # fallback
    #export LC_ALL="${LC_ALL:-ja_JP.UTF-8}" # For debug
    #export TZ=UTC
  }
  : "EDITOR, VISUAL, PAGER" && {
    ## EDITOR and pager config; require `neovim` and `less`
    if builtin command -v nvim > /dev/null 2>&1; then
      export EDITOR=${EDITOR:-nvim}
    else
      # TODO: elif vim not exist, use vi
      export EDITOR=${EDITOR:-vim}
    fi
    export VISUAL=$EDITOR
    export SYSTEMD_EDITOR=$EDITOR
    export PAGER="${PAGER:-less}"
  }
}

################################################################################
# XDG config
################################################################################
: "XDG" && {
  # --- XDG basics (resolve to runtime $HOME so bind-mounted dotfiles land right) ---
  export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
  export ZDOTDIR="${ZDOTDIR:-$XDG_CONFIG_HOME/zsh}"
  export XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"
  export XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
  export GNUPGHOME="${GNUPGHOME:-$XDG_DATA_HOME/gnupg}"
  export XDG_STATE_HOME="${XDG_STATE_HOME:-$HOME/.local/state}"
  # /run/user/$UID is created by pam_systemd (host) or baked into the
  # image at container build (Containerfile Stage 4) so this line works
  # identically in both — and tools that MkdirAll($XDG_RUNTIME_DIR) (e.g.
  # `chezmoi cd`) find it already present.
  export XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/$UID}"
}

################################################################################
# GPG and PGP
################################################################################
: "GPG" && {
  export GNUPGHOME="$XDG_DATA_HOME"/gnupg
}

################################################################################
# Minimum ZSH config
################################################################################
# Almost all ZSH config should be in dot_zshrc or mise config
# TODO: Is it really? should we manage these configs here or by sheldon?
: "ZSH config in zshenv" && {
  export ZDOTDIR="${ZDOTDIR:-$XDG_CONFIG_HOME/zsh}"
  : "ZSH history" && {
    if [[ ! -f $XDG_DATA_HOME/zsh/history ]]; then
      mkdir -p $XDG_DATA_HOME/zsh
      touch $XDG_DATA_HOME/zsh/history
    fi
    : "ZSH history config" && {
      # https://qiita.com/sho-t/items/d553dd694900cae0966d
      export HISTFILE=$XDG_DATA_HOME/zsh/history
      export HISTSIZE=10000
      export SAVEHIST=100000
      setopt appendhistory
      #setopt extend_history
      setopt share_history
      setopt inc_append_history
      #setopt inc_append_history_time
      setopt hist_allow_clobber
      setopt hist_expand
      setopt hist_fcntl_lock
      setopt hist_ignore_all_dups
      setopt hist_ignore_space
      setopt hist_reduce_blanks
      setopt hist_save_no_dups
      setopt hist_no_store
      setopt hist_verify
      # Don't consider certain characters part of the word
      WORDCHARS=${WORDCHARS//[\/&.;]/}
    }
  }
}

################################################################################
# GENERAL programming language path (Rust and mise managed)
################################################################################
# program languages may be called from outside of interactive shell, so write path here
: "GENERAL programming config" && {
  : "mise data" && {
    export MISE_DATA_DIR="${MISE_DATA_DIR:-$XDG_DATA_HOME/mise}"
  }
  : "Rust" && {
    export RUSTUP_HOME="${RUSTUP_HOME:-$XDG_DATA_HOME/rustup}"
    export CARGO_HOME="${CARGO_HOME:-$XDG_DATA_HOME/cargo}"
    path=($CARGO_HOME/bin(N-/) $path)
  }
  : "Go" && {
    export GOPATH="${GOPATH:-$MISE_DATA_DIR/installs/go/latest/packages}"
    export GOROOT="${GOROOT:-$MISE_DATA_DIR/installs/go/latest}"
  }
  : "Python" && {
    # cargo-dist 系インストーラ (uv 等) が rc ファイルを書き換えるのを抑止
    # https://opensource.axo.dev/cargo-dist/book/installers/shell.html
    export INSTALLER_NO_MODIFY_PATH=1
  }
  : "Java" && {
    export _JAVA_OPTIONS="${_JAVA_OPTIONS:-"-Djava.util.prefs.userRoot=$XDG_CONFIG_HOME/java"}"
    export GRADLE_USER_HOME="${GRADLE_USER_HOME:-$XDG_DATA_HOME/gradle}"
  }
  : "Node" && {
    export NODE_ENV="${NODE_ENV:-production}"
    export NPM_CONFIG_USERCONFIG="${NPM_CONFIG_USERCONFIG:-"$XDG_CONFIG_HOME"/npm/npmrc}"
    export PNPM_HOME="${PNPM_HOME:-$XDG_DATA_HOME/pnpm}"
    path=($PNPM_HOME $path)
  }
  # mise owns tool versions; stable global env/PATH defaults live above.
  : "mise" && {
    eval "$(mise activate zsh --shims)"
    path=($MISE_DATA_DIR/shims(N-/) $path)
  }
}

################################################################################
# GENERAL program config and path
################################################################################
# configs that run outside of interactive shell
: "OTHER PROGRAMS" && {
  : "X11" && {
    # LightDM cannot use XAUTHORITY
    #export XAUTHORITY=$XDG_CONFIG_HOME/Xauthority
    export XINITRC=$XDG_CONFIG_HOME/X11/xinitrc
    #export XSERVERRC=$XDG_CONFIG_HOME/X11/xserverrc
  }
  : "CUDA" && {
    export CUDA_CACHE_PATH="$XDG_CACHE_HOME"/nv
  }
}
