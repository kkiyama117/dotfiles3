
{{- /* chezmoi config — rendered by `chezmoi execute-template --init`.
   (It can evaluated in `chezmoi init` or other subcommands with `--init`.)
   build_mode is driven by the BUILD_MODE env var so the same template
   serves the build-prepass (BUILD_MODE=true) and the runtime entrypoint
   (BUILD_MODE unset -> false). This is a chezmoi config template
   (.chezmoi.$FORMAT.tmpl), executed prior to reading the source state,
   so it cannot read [data] it is generating — hence the env var. */ -}}
# Read https://www.chezmoi.io/reference/special-files/chezmoi-format-tmpl
# to know about the detail of the `chezmoi.toml.tmpl`.
[data]
build_mode = {{ if eq (env "BUILD_MODE" | default "false") "true" }}true{{ else }}false{{ end }}
runtime = {{ env "DOTFILES_RUNTIME" | default "host" | quote }}
pi_config_url = {{ env "PI_CONFIG_URL" | default "https://github.com/kkiyama117/pi-config.git" | quote }}
pi_config_ref = {{ env "PI_CONFIG_REF" | default "pi-config-v2026-07-08-1" | quote }}

{{- /* Git auto-commit via pi CLI hooks — host runtime only.
   The [git] and [hooks] sections are omitted entirely when running
   inside the container (DOTFILES_RUNTIME=container) or during the
   build-prepass (BUILD_MODE=true). Pattern from:
   https://ikuma-t.com/blog/commit-chezmoi-diff-automaticaly-by-claude/ */ -}}
{{- if and (eq (env "BUILD_MODE" | default "false") "false") (eq (env "DOTFILES_RUNTIME" | default "host") "host") }}
[git]
autoCommit = false
autoPush = false

[hooks.add.post]
command = "bash"
args = ["-c", "bash \"$(chezmoi source-path)/programs/chezmoi_pi_commit.sh\""]

[hooks.edit.post]
command = "bash"
args = ["-c", "bash \"$(chezmoi source-path)/programs/chezmoi_pi_commit.sh\""]
{{- end }}
