# It's base is root directory that dotfiles are applied
# for example: `~/.zshenv` -> `.zshenv`
# And some files that exists in this repository must be
# included in the ignore list to avoid conjection with
# the actual dotfiles

# ============================================================
# Repository metadata and programs itself
# ============================================================
container
dependencies
docs
programs
.env.example
AGENTS.md
Makefile
README.md

# Container-related files
.containerignore

# Chezmoi-related files
## It may be exposed by default
.chezmoiignore
.chezmoidata.yaml
.chezmoidata/*.yaml

# Git-related files
**/.git/
**/.git/**
**/.gitignore
**/.gitmodules
**/.worktrees

# ============================================================
# Bind mounts in the container
# ============================================================

# Toolchain / keyring volume mountpoints
## never managed by chezmoi

# Cargo: chezmoi manages ONLY ~/.local/share/cargo/config.toml. Everything
# else under $CARGO_HOME (bin, registry, git cache) is volume-owned.
.local/share/cargo/*
!.local/share/cargo/config.toml
!.local/share/cargo/binstall.toml

.local/share/rustup
.local/share/mise
.local/share/gnupg

# SSH: chezmoi manages ONLY ~/.ssh/config. Everything else under ~/.ssh/
# (private/public keys, known_hosts, config.d/*) is volume-owned and must
# never be touched by chezmoi. Exclude the whole tree, then re-include config.
.ssh/*
!.ssh/config

# Self bind-mount target (chezmoi source root)
.local/share/chezmoi

# ============================================================
# User generated files for dotfiles
# ============================================================
.env

