# Managed by chezmoi. Sourced by *interactive* zsh shells only.
#
# Runtime counterpart to the build-time-only "Toolchain HOMEs" block in
# .zshenv. The container build (Containerfile Stage 2 build-prepass) runs
# `chezmoi apply` with `build_mode = true` and renders .zshenv (with the
# toolchain HOMEs) into a scratch /tmp/build-home that Stage 3 sources and
# Stage 4 discards. The runtime entrypoint re-applies chezmoi against the
# real $HOME with `build_mode = false`, so the build-only block in .zshenv
# is omitted and THIS file re-establishes CARGO_HOME / RUSTUP_HOME /
# MISE_DATA_DIR and the toolchain PATH entries for interactive shells.
#
# NOTE: .zshrc is interactive-only, so non-interactive / non-login zsh
# invocations (e.g. `zsh -c`, `zsh -lc`) will NOT see these. This is
# intentional for now; the layout will be reworked via sheldon later.

{{ if not .build_mode -}}
: "Toolchain HOMEs (runtime)" && {
  export CARGO_HOME="${CARGO_HOME:-$XDG_DATA_HOME/cargo}"
  export RUSTUP_HOME="${RUSTUP_HOME:-$XDG_DATA_HOME/rustup}"
  export MISE_DATA_DIR="${MISE_DATA_DIR:-$XDG_DATA_HOME/mise}"
  path=($CARGO_HOME/bin(N-/) $MISE_DATA_DIR/shims(N-/) $path)
}
{{- end }}